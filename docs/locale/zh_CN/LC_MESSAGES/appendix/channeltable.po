#: ../../appendix/channeltable.md:1
msgid "Channel Table file"
msgstr "通道表文件"

#: ../../appendix/channeltable.md:3
msgid "Channel table file contains important information about channels."
msgstr "通道表文件中包含了通道的重要信息。"

#: ../../appendix/channeltable.md:5
msgid "Below is an example of one channel in channel table file:"
msgstr "下面是通道表中一个通道的信息："

#: ../../appendix/channeltable.md:9
msgid "\\[1\\]: Hexadecimal channel number (2-byte)"
msgstr "[1]: 十六进制通道号（2字节）"

#: ../../appendix/channeltable.md:10
msgid "\\[2\\]: Recording flag"
msgstr "[2]: 台站记录标识"

#: ../../appendix/channeltable.md:11
msgid "\\[3\\]: Delay time on a circuit (ms)"
msgstr "[3]: 电路延迟时间 (ms)"

#: ../../appendix/channeltable.md:12
msgid "\\[4\\]: Station code"
msgstr "[4]: 台站代码"

#: ../../appendix/channeltable.md:13
msgid "\\[5\\]: Motion component code"
msgstr "[5]: 分量代码"

#: ../../appendix/channeltable.md:14
msgid ""
"\\[6\\]: Reduction ratio of monitoring waveform (expressed as the integer "
"exponent of a power of 2)"
msgstr ""

#: ../../appendix/channeltable.md:15
msgid "\\[7\\]: Quantization bit rate in A/D conversion"
msgstr "[7]: A/D转换过程中的量化比特率"

#: ../../appendix/channeltable.md:16
msgid ""
"\\[8\\]: Sensor sensitivity (V/unit of input, where unit of input is "
"provided in column \\[9\\])"
msgstr "[8]: 传感器的敏感度 （单位是伏特每输出单位，其中输入单位由 [9] 列指定"

#: ../../appendix/channeltable.md:17
msgid ""
"\\[9\\]: Unit of input. Use MKS system: \"m\" for displacement, \"m/s\" for "
"velocity, and \"m/s/s\" for acceleration."
msgstr ""
"[9]: 输入单位。使用MKS系统： \"m\" 代表位移， \"m/s\" 代表速度，  \"m/s/s\" "
"代表加速度。"

#: ../../appendix/channeltable.md:18
msgid "\\[10\\]: Natural period of the seismometer (s)"
msgstr "[10]: 地震仪的自然周期 (s)"

#: ../../appendix/channeltable.md:19
msgid "\\[11\\]: Damping constant of the sensor"
msgstr "[11]: 传感器的阻尼常数"

#: ../../appendix/channeltable.md:20
msgid ""
"\\[12\\]: Amplification factor applied to sensor output prior to A/D "
"conversion (dB)"
msgstr "[12]: 在A/D转换前传感器输出的放大因子 (dB)"

#: ../../appendix/channeltable.md:21
msgid "\\[13\\]: Quantization width in A/D conversion (V), a.k.a. LSB value"
msgstr "[13]: A/D转换过程中的量化宽度（V），即LSB值"

#: ../../appendix/channeltable.md:22
msgid ""
"\\[14\\]: Station latitude (degrees). A positive value indicates North "
"latitude."
msgstr "[14]: 台站纬度。正值代表北纬。"

#: ../../appendix/channeltable.md:23
msgid ""
"\\[15\\]: Station longitude (degrees). A positive value indicates East "
"longitude."
msgstr "[15]: 台站经度。正值代表东经。"

#: ../../appendix/channeltable.md:24
msgid "\\[16\\]: Station height (m)"
msgstr "[16]: 台站高程 (m)"

#: ../../appendix/channeltable.md:25
msgid "\\[17\\]: Station correction for P-wave (s)"
msgstr "[17]: 台站P波校正 (s)"

#: ../../appendix/channeltable.md:26
msgid "\\[18\\]: Station correction for S-wave (s)"
msgstr "[18]: 台站S波校正 (s)"

#: ../../appendix/channeltable.md:27
msgid "\\[19\\]: Station name (Optional)"
msgstr "[19]: 台站名 (可选)"
